<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.april.rag.mapper.DocumentVectorMapper">
    <!-- 查询某个文件的所有向量分块 -->
    <select id="findByFileMd5"
            parameterType="java.lang.String"
            resultType="com.april.rag.entity.DocumentVector">
        SELECT
            *
        FROM
            document_vectors
        WHERE
            file_md5 = #{fileMd5}
    </select>

    <!-- 删除某个文件的所有向量分块 -->
    <delete id="deleteByFileMd5"
            parameterType="java.lang.String">
        DELETE
        FROM
            document_vectors
        WHERE
            file_md5 = #{fileMd5}
    </delete>

</mapper>